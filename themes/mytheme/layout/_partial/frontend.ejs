<% var initialPage = (typeof initialPage !== 'undefined' && initialPage) ? initialPage : 'home'; %>
<div id="frontendApp">
  <nav class="front-nav">
    <div class="nav-logo" onclick="showPage('home')">拾<span>墨</span></div>
    <div class="nav-links">
      <div class="nav-link <%= initialPage === 'home' ? 'active' : '' %>" id="navHome" onclick="showPage('home')">首页</div>
      <div class="nav-link <%= initialPage === 'articles' ? 'active' : '' %>" id="navArticles" onclick="showPage('articles')">文章</div>
      <div class="nav-link <%= initialPage === 'novels' ? 'active' : '' %>" id="navNovels" onclick="showPage('novels')">小说</div>
      <div class="nav-link <%= initialPage === 'about' ? 'active' : '' %>" id="navAbout" onclick="showPage('about')">关于</div>
    </div>
    <div class="nav-actions">
      <button class="btn btn-ghost btn-sm" onclick="showPage('login')">登录</button>
      <button class="btn btn-primary btn-sm" onclick="showPage('register')">注册</button>
    </div>
  </nav>

  <div class="page <%= initialPage === 'home' ? 'active' : '' %>" id="page-home">
    <section class="hero">
      <div class="hero-inner">
        <div>
          <div class="hero-eyebrow">Personal Writing Platform</div>
          <h1 class="hero-title">记录生命中的<br><em>每一刻灵光</em></h1>
          <p class="hero-desc">文字是我与世界的桥梁。这里有我对生活的思考、对文学的探索，以及那些尚未完成的故事。</p>
          <div class="hero-actions">
            <button class="hero-btn-primary" onclick="showPage('articles')">浏览文章</button>
            <button class="hero-btn-outline" onclick="showPage('novels')">阅读小说</button>
          </div>
        </div>
        <div class="hero-side">
          <div class="hero-card">
            <div style="font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.12em;color:rgba(255,255,255,.4);margin-bottom:.75rem">LATEST WORK</div>
            <div class="hero-card-title">《午后三时，光线斜切过窗棂》</div>
            <div class="hero-card-meta">随笔 · 2024.03.15 · 3 分钟阅读</div>
            <div class="hero-card-stats">
              <div class="hero-stat"><span class="hero-stat-val">48</span><span class="hero-stat-lbl">ARTICLES</span></div>
              <div class="hero-stat"><span class="hero-stat-val">5</span><span class="hero-stat-lbl">NOVELS</span></div>
              <div class="hero-stat"><span class="hero-stat-val">2.1k</span><span class="hero-stat-lbl">READERS</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="container">
      <div class="section-header">
        <div class="section-title">精选推荐</div>
      </div>
      <div class="featured-article" onclick="showPage('article')">
        <div class="featured-body">
          <div class="featured-label">Editor's Pick</div>
          <h2 class="featured-title">在文字的迷宫里寻找出口——关于写作与存在的长篇思考</h2>
          <p class="featured-excerpt">我们为什么要写作？不是为了被记住，不是为了留下什么，而是为了在那一刻，语言帮助我们厘清混沌，让那些浮动于意识边缘的感受变得真实而可触碰。这篇文章试图回答这个困扰我多年的问题……</p>
          <div class="card-meta">
            <span>2024-03-10</span>
            <span>·</span>
            <span>12 分钟阅读</span>
            <span>·</span>
            <span>3,241 次阅读</span>
          </div>
        </div>
        <div class="featured-cover">📖</div>
      </div>

      <div class="cat-tabs">
        <div class="cat-tab active">全部</div>
        <div class="cat-tab">文章</div>
        <div class="cat-tab">随笔</div>
        <div class="cat-tab">评论</div>
      </div>

      <div class="articles-grid"></div>

      <div class="section-header">
        <div class="section-title">连载小说</div>
        <div class="section-more" onclick="showPage('novels')">查看全部 →</div>
      </div>
      <div class="novels-grid"></div>
    </div>

    <footer class="front-footer">
      <div class="footer-inner">
        <div class="footer-logo">拾墨</div>
        <p style="font-size:13px;margin-top:.5rem;max-width:360px;line-height:1.7">一个关于文字、思考与创作的私人空间。感谢你的到来。</p>
        <div class="footer-bottom">
          <span>© 2024 拾墨 · 保留所有权利</span>
          <span>Powered by Next.js · Neon · Vercel</span>
        </div>
      </div>
    </footer>
  </div>

  <div class="page <%= initialPage === 'article' ? 'active' : '' %>" id="page-article">
    <div class="container">
      <div class="article-header">
        <div class="article-breadcrumb">
          <span onclick="showPage('home')">首页</span>
          <span style="color:var(--border-2)">›</span>
          <span>文章</span>
        </div>
        <div class="article-tags" style="margin-bottom:1rem"></div>
        <h1 class="article-headline"></h1>
        <div class="article-meta-row">
          <div class="article-meta-item">📅 --</div>
          <div class="article-meta-item">⏱ --</div>
          <div class="article-meta-item">👁 --</div>
          <div class="article-meta-item">💬 --</div>
        </div>
      </div>
    </div>
    <div class="container">
      <div class="article-layout">
        <div class="article-content"></div>
        <div class="media-panel">
          <div class="media-panel-label">配图与媒体</div>
          <div class="media-item">
            <div class="media-img">📚</div>
            <div class="media-caption">媒体面板</div>
          </div>
        </div>
      </div>
    </div>
    <div class="container-sm">
      <div class="comments-section">
        <div class="comments-title">评论</div>
        <div class="comment-input-area">
          <textarea placeholder="写下你的想法……（登录后才能评论）" readonly onclick="showPage('login')"></textarea>
          <div class="comment-input-footer">
            <div class="comment-user-info">
              <div class="comment-avatar">?</div>
              <span>请先登录</span>
            </div>
            <button class="btn btn-primary btn-sm" onclick="showPage('login')">登录后评论</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="page <%= initialPage === 'novels' ? 'active' : '' %>" id="page-novels">
    <div class="page-hero">
      <div class="page-hero-inner">
        <h1>连载小说</h1>
        <p>正在进行中的故事，以及那些已经画上句号的世界</p>
      </div>
    </div>
    <div class="container">
      <div class="cat-tabs" style="padding-top:2rem">
        <div class="cat-tab active">全部</div>
        <div class="cat-tab">连载中</div>
        <div class="cat-tab">已完结</div>
        <div class="cat-tab">科幻</div>
        <div class="cat-tab">奇幻</div>
        <div class="cat-tab">现实主义</div>
      </div>
      <div class="novels-list-grid"></div>
    </div>
  </div>

  <div class="page <%= initialPage === 'chapter' ? 'active' : '' %>" id="page-chapter">
    <div class="chapter-header">
      <div class="chapter-back" onclick="showPage('novels')">← 返回目录</div>
      <div class="chapter-title-bar">小说阅读</div>
      <div class="chapter-nav-btns">
        <button class="btn btn-outline btn-sm">← 上一章</button>
        <button class="btn btn-primary btn-sm">下一章 →</button>
      </div>
    </div>
    <div class="reading-progress"><div class="reading-progress-bar"></div></div>
    <div class="chapter-reader-layout">
      <div class="chapter-content-wrap">
        <span class="chapter-num-label">章节</span>
        <h1 class="chapter-title">章节标题</h1>
        <div class="chapter-body"></div>
        <div class="chapter-nav-footer">
          <button class="btn btn-outline">← 上一章</button>
          <button class="btn btn-primary">下一章 →</button>
        </div>
      </div>
      <div>
        <div class="chapter-toc">
          <div class="chapter-toc-header">章节目录</div>
          <div class="chapter-toc-list"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="page <%= initialPage === 'about' ? 'active' : '' %>" id="page-about">
    <div class="page-hero">
      <div class="page-hero-inner">
        <h1>关于作者</h1>
        <p>一个喜欢用文字思考的人</p>
      </div>
    </div>
    <div class="container-sm" style="padding:3rem 2rem 5rem">
      <div style="display:flex;gap:3rem;align-items:flex-start;margin-bottom:3rem">
        <div style="width:120px;height:120px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--gold));flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:2.5rem;color:white">✍</div>
        <div>
          <h2 style="font-family:'Playfair Display',serif;font-size:1.8rem;margin-bottom:.5rem">某位写作者</h2>
          <p style="color:var(--ink-3);font-size:.9rem;margin-bottom:1rem;font-family:'DM Mono',monospace">作家 · 随笔作者 · 小说创作者</p>
          <div style="display:flex;gap:.75rem;flex-wrap:wrap">
            <span class="tag tag-green">文学</span>
            <span class="tag tag-gold">哲学</span>
            <span class="tag tag-blue">电影</span>
            <span class="tag tag-gray">旅行</span>
          </div>
        </div>
      </div>
      <div style="font-size:1.02rem;line-height:1.9;color:var(--ink-2)">
        <p>这是一个关于文字与思考的私人空间。</p>
      </div>
    </div>
  </div>

  <div class="page <%= initialPage === 'articles' ? 'active' : '' %>" id="page-articles">
    <div class="page-hero">
      <div class="page-hero-inner">
        <h1>全部文章</h1>
        <p>文章、随笔与评论</p>
      </div>
    </div>
    <div class="container">
      <div class="cat-tabs" style="padding-top:2rem">
        <div class="cat-tab active">全部</div>
        <div class="cat-tab">文章</div>
        <div class="cat-tab">随笔</div>
        <div class="cat-tab">评论</div>
      </div>
      <div class="articles-grid"></div>
      <div class="pagination" style="border-color:var(--border)">
        <button class="page-btn active" style="background:var(--accent);border-color:var(--accent);color:white">1</button>
        <button class="page-btn" style="border-color:var(--border-2);color:var(--ink-3)">2</button>
        <button class="page-btn" style="border-color:var(--border-2);color:var(--ink-3)">→</button>
      </div>
    </div>
  </div>

  <div class="page <%= initialPage === 'login' ? 'active' : '' %>" id="page-login">
    <div class="auth-page">
      <div class="auth-card">
        <div class="auth-logo"><div class="auth-logo-text">拾墨</div></div>
        <h2 class="auth-title">欢迎回来</h2>
        <p class="auth-subtitle">登录你的账号，加入对话</p>
        <div class="form-group">
          <label class="form-label">邮箱地址</label>
          <input type="text" id="loginUsername" class="form-input" placeholder="输入用户名">
        </div>
        <div class="form-group">
          <label class="form-label">密码</label>
          <input type="password" id="loginPassword" class="form-input" placeholder="输入密码">
        </div>
        <button class="form-submit" onclick="handleLogin()">登录</button>
        <div class="auth-switch">还没有账号？<span onclick="showPage('register')">立即注册</span></div>
      </div>
    </div>
  </div>

  <div class="page <%= initialPage === 'register' ? 'active' : '' %>" id="page-register">
    <div class="auth-page">
      <div class="auth-card">
        <div class="auth-logo"><div class="auth-logo-text">拾墨</div></div>
        <h2 class="auth-title">创建账号</h2>
        <p class="auth-subtitle">加入读者社区，参与内容讨论</p>
        <div class="form-group">
          <label class="form-label">昵称</label>
          <input type="text" class="form-input" placeholder="你的显示名称">
        </div>
        <div class="form-group">
          <label class="form-label">邮箱地址</label>
          <input type="email" class="form-input" placeholder="your@email.com">
        </div>
        <div class="form-group">
          <label class="form-label">密码</label>
          <input type="password" class="form-input" placeholder="至少 8 位字符">
        </div>
        <div class="form-group">
          <label class="form-label">确认密码</label>
          <input type="password" class="form-input" placeholder="再次输入密码">
        </div>
        <button class="form-submit">注册</button>
        <div class="auth-switch">已有账号？<span onclick="showPage('login')">直接登录</span></div>
      </div>
    </div>
  </div>
</div>
