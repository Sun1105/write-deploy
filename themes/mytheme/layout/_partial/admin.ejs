      <div class="admin-page" id="adminPage-articles">
        <div class="admin-header">
          <div class="admin-page-title">文章管理</div>
          <div class="admin-header-actions">
            <div class="admin-search"><span class="admin-search-icon">🔍</span><input id="adminArticleSearch" placeholder="搜索文章…"></div>
            <button class="btn btn-admin" onclick="newPost()">+ 新建文章</button>
          </div>
        </div>
        <div class="admin-content">
          <div class="top-tabs">
            <div class="top-tab active" data-filter="all">全部 <span class="tab-count" id="adminArticleCountAll">0</span></div>
            <div class="top-tab" data-filter="published">已发布 <span class="tab-count" id="adminArticleCountPublished">0</span></div>
            <div class="top-tab" data-filter="draft">草稿 <span class="tab-count" id="adminArticleCountDraft">0</span></div>
            <div class="top-tab" data-filter="archived">已归档 <span class="tab-count" id="adminArticleCountArchived">0</span></div>
          </div>
          <div class="table-card">
            <div class="table-card-header">
              <div class="table-card-title">文章列表</div>
              <div style="display:flex;gap:.5rem">
                <select id="adminArticleCategoryFilter" style="padding:.3rem .6rem;background:var(--admin-bg);border:1px solid var(--admin-border);border-radius:5px;color:var(--admin-muted);font-size:12px">
                  <option value="">全部分类</option>
                </select>
              </div>
            </div>
            <div class="table-wrap">
              <table class="admin-table">
                <thead><tr><th>标题</th><th>分类</th><th>状态</th><th>阅读量</th><th>评论</th><th>发布时间</th><th>操作</th></tr></thead>
                <tbody id="articleListBody"></tbody>
              </table>
            </div>
          </div>
          <div class="pagination" id="adminArticlePagination"></div>
        </div>
      </div>

      <div class="admin-page" id="adminPage-editor">
        <div class="admin-header">
          <div class="admin-page-title">写作编辑器</div>
          <div class="admin-header-actions">
            <button class="btn btn-admin-outline btn-sm" onclick="saveEditor(false)">保存</button>
            <button class="btn btn-admin btn-sm" onclick="saveEditor(true)">发布</button>
          </div>
        </div>
        <div class="admin-content">
          <div class="editor-wrap">
            <input class="editor-title-input" id="editorTitle" placeholder="输入文章标题…" value="">
            <div class="editor-toolbar">
              <button class="toolbar-btn active" title="加粗"><b>B</b></button>
              <button class="toolbar-btn" title="斜体"><i>I</i></button>
              <button class="toolbar-btn" title="下划线"><u>U</u></button>
              <div class="toolbar-sep"></div>
              <button class="toolbar-btn">H1</button>
              <button class="toolbar-btn">H2</button>
              <button class="toolbar-btn">H3</button>
              <div class="toolbar-sep"></div>
              <button class="toolbar-btn">≡</button>
              <button class="toolbar-btn">❝</button>
              <button class="toolbar-btn">&lt;/&gt;</button>
              <div class="toolbar-sep"></div>
              <button class="toolbar-btn">🔗</button>
              <button class="toolbar-btn">—</button>
              <div class="toolbar-sep"></div>
              <button class="toolbar-btn" style="width:auto;padding:0 8px;font-size:11px;color:var(--admin-muted)">撤销</button>
              <button class="toolbar-btn" style="width:auto;padding:0 8px;font-size:11px;color:var(--admin-muted)">重做</button>
            </div>
            <div class="editor-layout">
              <div class="editor-body">
                <textarea class="editor-textarea" id="editorContent" placeholder="开始写作…"></textarea>
              </div>
              <div class="editor-sidebar-panel">
                <div class="editor-panel-title">文章设置</div>
                <div class="editor-field">
                  <label class="editor-label">内容类型</label>
                  <select class="editor-input" id="editorMode" style="height:36px">
                    <option value="post">文章</option>
                    <option value="novel">小说章节</option>
                  </select>
                </div>

                <div id="editorNovelFields" style="display:none">
                  <div class="editor-field">
                    <label class="editor-label">小说</label>
                    <select class="editor-input" id="editorNovelId" style="height:36px">
                      <option value="">选择小说…</option>
                    </select>
                  </div>
                  <div class="editor-field">
                    <label class="editor-label">章节文件名</label>
                    <input class="editor-input" id="editorChapterFilename" placeholder="例如：001-第一章.md">
                  </div>
                </div>

                <div id="editorPostFields">
                <div class="editor-field">
                  <label class="editor-label">分类</label>
                  <input class="editor-input" id="editorCategory" placeholder="例如：文章, 随笔">
                </div>
                <div class="editor-field">
                  <label class="editor-label">标签</label>
                  <input class="editor-input" id="editorTags" placeholder="例如：写作, 随想">
                </div>
                <div class="editor-field">
                  <label class="editor-label">摘要</label>
                  <textarea class="editor-input" id="editorExcerpt" style="min-height:70px;resize:none;line-height:1.6" placeholder="用于列表与 SEO"></textarea>
                </div>
                <div class="editor-field">
                  <label class="editor-label">文件名/Slug</label>
                  <input class="editor-input" id="editorSlug" placeholder="例如：memory-and-forgetting">
                </div>
                </div>
                <div class="editor-panel-title" style="margin-top:1.25rem">媒体上传</div>
                <div class="upload-zone" onclick="document.getElementById('mediaInput').click()">
                  <div class="upload-zone-icon">📁</div>
                  <div class="upload-zone-text">点击或拖拽上传<br>图片 / GIF / 视频 (≤100MB)</div>
                  <input type="file" id="mediaInput" hidden onchange="uploadMedia(this.files[0])">
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="admin-page" id="adminPage-novels">
        <div class="admin-header">
          <div class="admin-page-title">小说管理</div>
          <div class="admin-header-actions">
            <button class="btn btn-admin" onclick="createNovel()">+ 新建小说</button>
          </div>
        </div>
        <div class="admin-content">
          <div class="table-card">
            <div class="table-card-header"><div class="table-card-title">小说列表</div></div>
            <div class="table-wrap">
              <table class="admin-table">
                <thead><tr><th>小说名</th><th>类型</th><th>章节数</th><th>总字数</th><th>状态</th><th>最后更新</th><th>操作</th></tr></thead>
                <tbody id="novelListBody"></tbody>
              </table>
            </div>
          </div>

          <div class="table-card" id="novelChaptersCard" style="margin-top:1rem;display:none">
            <div class="table-card-header" style="display:flex;align-items:center;justify-content:space-between;gap:12px">
              <div class="table-card-title" id="novelChaptersTitle">章节管理</div>
              <div style="display:flex;gap:.5rem">
                <button class="btn btn-admin-outline btn-sm" onclick="newNovelChapter()">新建章节</button>
                <button class="btn btn-admin btn-sm" onclick="saveNovelChapter()">保存章节</button>
                <button class="btn btn-sm" style="color:var(--red);border:1px solid rgba(239,68,68,.3);border-radius:5px;padding:.3rem .7rem;font-size:12px;background:transparent" onclick="deleteNovelChapter()">删除章节</button>
              </div>
            </div>
            <div style="display:grid;grid-template-columns:260px 1fr;gap:12px;padding:12px">
              <div style="border:1px solid var(--admin-border);border-radius:8px;padding:10px;max-height:420px;overflow:auto">
                <div id="novelChaptersList"></div>
              </div>
              <div style="display:flex;flex-direction:column;gap:.6rem">
                <input class="settings-input" id="novelChapterFilename" placeholder="章节文件名，如 001-第一章.md" />
                <textarea class="editor-textarea" id="novelChapterContent" style="min-height:380px"></textarea>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="admin-page" id="adminPage-comments">
        <div class="admin-header">
          <div class="admin-page-title">评论审核</div>
          <div id="adminCommentsSummary" style="margin-left:auto;font-size:13px;color:var(--admin-muted)">0 条待审核</div>
        </div>
        <div class="admin-content">
          <div class="top-tabs">
            <div class="top-tab active" data-filter="all">全部 <span class="tab-count" id="adminCommentCountAll">0</span></div>
            <div class="top-tab" data-filter="pending">待审核 <span class="tab-count" id="adminCommentCountPending">0</span></div>
            <div class="top-tab" data-filter="approved">已通过 <span class="tab-count" id="adminCommentCountApproved">0</span></div>
            <div class="top-tab" data-filter="hidden">已隐藏 <span class="tab-count" id="adminCommentCountHidden">0</span></div>
          </div>
        </div>
      </div>

      <div class="admin-page" id="adminPage-users">
        <div class="admin-header">
          <div class="admin-page-title">用户管理</div>
          <div class="admin-header-actions">
            <div class="admin-search"><span class="admin-search-icon">🔍</span><input placeholder="搜索用户…"></div>
          </div>
        </div>
        <div class="admin-content">
          <div class="top-tabs">
            <div class="top-tab active">全部用户 <span class="tab-count">1,284</span></div>
            <div class="top-tab">正常 <span class="tab-count">1,278</span></div>
            <div class="top-tab">已封禁 <span class="tab-count">6</span></div>
          </div>
          <div class="table-card">
            <div class="table-wrap">
              <table class="admin-table">
                <thead><tr><th>用户</th><th>邮箱</th><th>角色</th><th>状态</th><th>评论数</th><th>注册时间</th><th>操作</th></tr></thead>
                <tbody></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="admin-page" id="adminPage-settings">
        <div class="admin-header">
          <div class="admin-page-title">网站设置</div>
          <div class="admin-header-actions">
            <button class="btn btn-admin" onclick="saveSettings()">保存更改</button>
          </div>
        </div>
        <div class="admin-content">
          <div class="settings-section">
            <div class="settings-section-header">
              <div class="settings-section-title">基本信息</div>
              <div class="settings-section-desc">网站名称、描述与联系方式</div>
            </div>
            <div class="settings-body">
              <div class="settings-row">
                <div class="settings-label-wrap"><div class="settings-label">网站名称</div><div class="settings-desc">显示在浏览器标签和网站 Logo 处</div></div>
                <input class="settings-input" value="拾墨">
              </div>
              <div class="settings-row">
                <div class="settings-label-wrap"><div class="settings-label">网站简介</div><div class="settings-desc">显示在 SEO meta description 和关于页</div></div>
                <input class="settings-input" value="一个关于文字、思考与创作的私人空间">
              </div>
              <div class="settings-row">
                <div class="settings-label-wrap"><div class="settings-label">作者名</div><div class="settings-desc">文章署名与关于页显示</div></div>
                <input class="settings-input" value="某位写作者">
              </div>
            </div>
          </div>

          <div class="settings-section">
            <div class="settings-section-header">
              <div class="settings-section-title">功能开关</div>
              <div class="settings-section-desc">控制前台功能的开启与关闭</div>
            </div>
            <div class="settings-body">
              <div class="settings-row">
                <div class="settings-label-wrap"><div class="settings-label">允许注册</div><div class="settings-desc">关闭后访客无法注册新账号</div></div>
                <div class="settings-toggle-row"><div class="settings-toggle on" onclick="this.classList.toggle('on')"><div class="settings-toggle-knob"></div></div></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
