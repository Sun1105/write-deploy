          <div class="admin-quick-links">
            <div class="quick-link" onclick="newPost()"><div class="quick-link-icon">✏️</div><div class="quick-link-label">写新文章</div></div>
            <div class="quick-link" onclick="showAdminPage('comments')"><div class="quick-link-icon">💬</div><div class="quick-link-label">审核评论 (7)</div></div>
            <div class="quick-link" onclick="showAdminPage('novels')"><div class="quick-link-icon">📖</div><div class="quick-link-label">更新小说</div></div>
